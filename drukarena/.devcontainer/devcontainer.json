{
  "name": "DrukArena - Go & PostgreSQL",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspaces/drukarena",
  "customizations": {
    "vscode": {
      "extensions": [
        "golang.go",
        "ckolkman.vscode-postgres",
        "humao.rest-client",
        "ms-azuretools.vscode-docker"
      ],
      "settings": {
        "go.toolsManagement.checkForUpdates": "local",
        "go.useLanguageServer": true,
        "go.gopath": "/go",
        "editor.formatOnSave": true,
        "[go]": {
          "editor.defaultFormatter": "golang.go"
        }
      }
    }
  },
  "forwardPorts": [8080, 5432],
  "postCreateCommand": "cd /workspaces/drukarena && go mod tidy && go install github.com/air-verse/air@latest",
  "remoteUser": "vscode"
}
